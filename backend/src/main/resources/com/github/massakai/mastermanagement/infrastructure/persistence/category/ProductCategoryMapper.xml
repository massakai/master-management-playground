<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.massakai.mastermanagement.infrastructure.persistence.category.ProductCategoryMapper">
    <resultMap id="ProductCategoryRecordMap" type="com.github.massakai.mastermanagement.infrastructure.persistence.category.ProductCategoryRecord">
        <constructor>
            <arg column="category_code" javaType="string"/>
            <arg column="category_name" javaType="string"/>
            <arg column="display_order" javaType="int"/>
            <arg column="is_active" javaType="boolean"/>
            <arg column="description" javaType="string"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectAllOrdered" resultMap="ProductCategoryRecordMap">
        SELECT
            category_code,
            category_name,
            display_order,
            is_active,
            description,
            created_at,
            updated_at
        FROM product_category
        ORDER BY display_order ASC, category_code ASC
    </select>

    <delete id="deleteAll">
        DELETE FROM product_category
    </delete>

    <insert id="insert" parameterType="com.github.massakai.mastermanagement.infrastructure.persistence.category.ProductCategoryRecord">
        INSERT INTO product_category (
            category_code,
            category_name,
            display_order,
            is_active,
            description,
            created_at,
            updated_at
        ) VALUES (
            #{categoryCode},
            #{categoryName},
            #{displayOrder},
            #{isActive},
            #{description},
            #{createdAt},
            #{updatedAt}
        )
    </insert>
</mapper>
